# ── Виртуальные окружения ───────────────────────────────────────────
.venv/
venv/
env/

# ── Python кэш / артефакты ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Сборка (PyInstaller / Inno Setup) ───────────────────────────────
build/
dist/
*.manifest

# ── Большие бинарники: качаются/собираются отдельно ─────────────────
# Модель (~215 МБ) — скачивается с HuggingFace при первом запуске
models/
# ffmpeg/ffprobe (~97 МБ каждый) — скачивает build.bat
packaging/ffmpeg/

# ── Логи и временное ────────────────────────────────────────────────
*.log
censr_error.log
*.report.json

# ── Локальные/агентские файлы ───────────────────────────────────────
.claude/
tasks/
push-to-github.bat
CLAUDE.md

# ── ОС ──────────────────────────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini
